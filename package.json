{
  "name": "@crispui/react",
  "version": "0.1.0",
  "description": "A React + TypeScript + Tailwind CSS UI component library with productivity, data display, motion, and form components",
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/crisp.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/crisp.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npx @tailwindcss/cli -i ./src/styles/index.css -o ./dist/crisp.css --minify",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "framer-motion": "^12.38.0",
    "iconsax-react": "^0.0.8",
    "tailwind-merge": "^2.3.0"
  },
  "keywords": [
    "react",
    "typescript",
    "tailwindcss",
    "ui",
    "components",
    "pomodoro",
    "kanban",
    "habit-tracker",
    "data-table",
    "skeleton"
  ],
  "publishConfig": {
    "access": "public"
  }
}
